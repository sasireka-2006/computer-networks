import sys

def solve():
    input = sys.stdin.read
    data = input().split()
    if not data:
        return
    
    t = int(data[0])
    for i in range(1, t + 1):
        s = data[i]
        digit_sum = sum(int(char) for char in s if char.isdigit())
        print(digit_sum)

if __name__ == '__main__':
    solve()
